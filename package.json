{
  "name": "mcp-jvm-debugger",
  "version": "0.1.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "build:java": "mvn -f java-agent\\pom.xml package",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "test": "node --test -r ts-node/register -r tsconfig-paths/register test/**/*.test.ts",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"docs/**/*.md\" \"README.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"docs/**/*.md\" \"README.md\"",
    "deadcode:check": "ts-prune -p tsconfig.json",
    "install:integrations:sh": "bash ./scripts/install-integrations.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nimbly-dev/mcp-jvm-debugger.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/nimbly-dev/mcp-jvm-debugger/issues"
  },
  "homepage": "https://github.com/nimbly-dev/mcp-jvm-debugger#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@hono/node-server": "^1.19.11",
    "hono": "^4.12.5"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "@types/node": "^25.2.3",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "ts-prune": "^0.10.3",
    "typescript": "^5.9.3"
  },
  "bin": {
    "mcp-jvm-debugger": "dist/server.js"
  },
  "files": [
    "dist/**",
    "java-agent/request-mapping-resolver/target/*.jar",
    "README.md"
  ]
}
