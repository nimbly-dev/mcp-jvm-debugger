{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDir": ".",
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["tools/transport/tools-mcp-server/src/*"],
      "@test/*": ["test/*"],
      "@tools-core/*": ["tools/core/tools-core/src/*"],
      "@tools-registry/*": ["tools/core/tools-registry/src/*"],
      "@tools-spring-http/*": ["tools/synthesizers/tools-spring-http/src/*"]
    },

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "module": "commonjs",
    "target": "es2022",
    "types": ["node"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    // For nodejs:
    // "lib": ["esnext"],
    // "types": ["node"],
    // and npm install -D @types/node

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
  },
  "include": [
    "server.ts",
    "tools/transport/tools-mcp-server/src/**/*.ts",
    "tools/core/tools-core/src/**/*.ts",
    "tools/core/tools-registry/src/**/*.ts",
    "tools/synthesizers/tools-spring-http/src/**/*.ts"
  ],
  "exclude": ["dist", "test", "node_modules"]
}
